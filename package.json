{
  "name": "baby-swe",
  "version": "1.0.0",
  "description": "A basic Electron application with TypeScript and Tailwind",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npm run build && electron .",
    "build": "tsc && cp ./src/index.html ./dist/index.html && tailwindcss -i ./src/styles/input.css -o ./dist/styles/output.css",
    "watch": "concurrently \"tsc -w\" \"tailwindcss -i ./src/styles/input.css -o ./dist/styles/output.css --watch\"",
    "start": "electron ."
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}
