{
  "name": "baby-swe",
  "productName": "Baby SWE",
  "version": "0.1.0",
  "description": "A terminal-style AI coding assistant",
  "main": "dist/main.js",
  "scripts": {
    "dev": "bun run build && electron .",
    "watch": "bun run build && concurrently -k \"bun run watch:main\" \"bun run watch:renderer\" \"bun run watch:css\" \"bun run watch:electron\"",
    "build": "tsc -p tsconfig.main.json && bun run build:renderer && cp ./src/index.html ./dist/index.html && tailwindcss -i ./src/styles/input.css -o ./dist/styles/output.css && cp -r ./assets ./dist/assets",
    "build:renderer": "esbuild src/renderer.tsx src/ui/monaco/editor.worker.ts src/ui/monaco/json.worker.ts src/ui/monaco/css.worker.ts src/ui/monaco/html.worker.ts src/ui/monaco/ts.worker.ts --bundle --outdir=dist --platform=browser --target=chrome120 --loader:.ttf=file",
    "watch:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "watch:renderer": "bun run build:renderer --watch",
    "watch:css": "tailwindcss -i ./src/styles/input.css -o ./dist/styles/output.css --watch",
    "watch:electron": "electronmon .",
    "start": "electron .",
    "pack": "bun run build && electron-builder --dir",
    "dist": "bun run build && electron-builder",
    "dist:mac": "bun run build && electron-builder --mac",
    "dist:win": "bun run build && electron-builder --win",
    "dist:linux": "bun run build && electron-builder --linux"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.12",
    "@langchain/core": "^1.1.25",
    "@langchain/openai": "^1.2.3",
    "@tavily/core": "^0.7.1",
    "@xterm/addon-fit": "^0.11.0",
    "deepagents": "^1.8.0",
    "diff": "^8.0.3",
    "dotenv": "^17.2.3",
    "langchain": "^1.2.15",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.22.0",
    "turndown": "^7.2.2",
    "uuid": "^9.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zod": "^4.3.6",
    "zustand": "^4.5.0"
  },
  "build": {
    "appId": "com.baby-swe.app",
    "productName": "Baby SWE",
    "icon": "assets/icon.icns",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "npmRebuild": true
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^9.0.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^26.7.0",
    "electron-rebuild": "^3.2.9",
    "electronmon": "^2.0.4",
    "esbuild": "^0.27.2",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}
