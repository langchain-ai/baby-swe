{
  "name": "baby-swe",
  "version": "1.0.0",
  "description": "A basic Electron application with TypeScript and Tailwind",
  "main": "dist/main.js",
  "scripts": {
    "dev": "bun run build && electron .",
    "build": "tsc -p tsconfig.main.json && esbuild src/renderer.tsx --bundle --outfile=dist/renderer.js --platform=browser --target=chrome120 && cp ./src/index.html ./dist/index.html && tailwindcss -i ./src/styles/input.css -o ./dist/styles/output.css",
    "watch": "concurrently \"tsc -w\" \"tailwindcss -i ./src/styles/input.css -o ./dist/styles/output.css --watch\"",
    "start": "electron ."
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.12",
    "@langchain/core": "^1.1.17",
    "@langchain/openai": "^1.2.3",
    "deepagents": "^1.6.1",
    "dotenv": "^17.2.3",
    "langchain": "^1.2.15",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.0",
    "zod": "^4.3.6",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "esbuild": "^0.27.2",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}
